# ─── Database ─────────────────────────────────────────────────────────────────
# Supabase connection string (Transaction mode pooler recommended for serverless)
DATABASE_URL="postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres"

# ─── App ──────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Used to sign session tokens issued after email/password login
JWT_SECRET="replace-with-a-long-random-secret"

# ─── Stripe ───────────────────────────────────────────────────────────────────
# Test keys from dashboard.stripe.com — never commit live keys
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Stripe Price IDs — create one-time payment prices in the Stripe dashboard
# Products → Add product → One-time payment → copy the price_... ID
STRIPE_PRICE_STARTER="price_..."
STRIPE_PRICE_GROWTH="price_..."
STRIPE_PRICE_SCALE="price_..."

# ─── Email ────────────────────────────────────────────────────────────────────
RESEND_API_KEY="re_your_resend_key_here"

# ─── AI / Playground ──────────────────────────────────────────────────────────
# Default LLM for the prompt playground (no credit card required)
GEMINI_API_KEY=""

# AES-256-GCM key for encrypting user BYOK LLM keys (32 bytes as 64-char hex)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_SECRET=""
