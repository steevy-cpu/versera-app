# ─── Database ─────────────────────────────────────────────────────────────────
# Supabase connection string (Transaction mode pooler recommended for serverless)
DATABASE_URL="postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres"

# ─── App ──────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Used to sign session tokens issued after email/password login
JWT_SECRET="replace-with-a-long-random-secret"

# ─── Stripe ───────────────────────────────────────────────────────────────────
# Test keys from dashboard.stripe.com — never commit live keys
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
